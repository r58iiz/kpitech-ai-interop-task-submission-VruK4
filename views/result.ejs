<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Verify Claim' }) %>
  <style>
    .page-header {
      padding: 36px 0 24px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 32px;
    }
    .page-header h1 {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 4px;
    }
    .page-header p { font-size: 14px; color: var(--muted); }

    /* ── Claim Input ─────────────────────────────────────────── */
    .claim-form {
      display: flex;
      gap: 10px;
      margin-bottom: 32px;
      align-items: flex-start;
    }
    .claim-input-wrap {
      flex: 1;
      position: relative;
    }
    .claim-input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border-hi);
      border-radius: var(--radius);
      color: var(--text);
      font-family: var(--font);
      font-size: 15px;
      padding: 12px 16px 12px 44px;
      outline: none;
      transition: border-color 0.2s;
      resize: none;
    }
    .claim-input::placeholder { color: var(--muted); }
    .claim-input:focus { border-color: var(--accent); }

    .claim-icon {
      position: absolute;
      left: 14px;
      top: 14px;
      color: var(--muted);
      pointer-events: none;
    }

    /* ── Status bar ──────────────────────────────────────────── */
    .status-bar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 20px;
    }
    .status-bar.hidden { display: none; }
    .status-step { font-family: var(--mono); font-size: 11px; }

    /* ── Result layout ───────────────────────────────────────── */
    .result-grid {
      display: grid;
      gap: 20px;
    }

    /* ── Loading skeleton ────────────────────────────────────── */
    .skeleton {
      background: linear-gradient(90deg, var(--surface) 25%, var(--border) 50%, var(--surface) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 4px;
      height: 14px;
    }
    @keyframes shimmer { to { background-position: -200% 0; } }

    .skeleton-block {
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 24px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }

    /* ── Suggested claims ────────────────────────────────────── */
    .suggestions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 28px;
    }
    .suggestion-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      width: 100%;
      margin-bottom: 2px;
    }
    .suggestion-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 12px;
      background: var(--surface);
      border: 1px solid var(--border-hi);
      border-radius: 20px;
      font-size: 12.5px;
      color: var(--muted);
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
    }
    .suggestion-chip:hover { color: var(--text); border-color: var(--accent); }
  </style>
</head>
<body>

  <%- include('partials/navbar', { activePage: 'result' }) %>

  <main>
    <div class="container">
      <div class="page-header">
        <h1>Verify a Claim</h1>
        <p>Enter a plain-English claim or question. The system retrieves recent news, scores relevance, and produces a source-grounded answer.</p>
      </div>

      <!-- Claim input form -->
      <form class="claim-form" id="claimForm" action="/result" method="POST">
        <div class="claim-input-wrap">
          <svg class="claim-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          <textarea
            class="claim-input"
            name="claim"
            id="claimInput"
            rows="2"
            placeholder="e.g. Is US inflation declining in 2025?"
            required
          ><%= typeof claim !== 'undefined' ? claim : '' %></textarea>
        </div>
        <button type="submit" class="btn btn-primary" id="submitBtn">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
            <path d="M1.5 7.5h12M8.5 3l4.5 4.5-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Verify
        </button>
      </form>

      <!-- Suggested claims (shown only when no result yet) -->
      <% if (typeof sources === 'undefined' || !sources) { %>
      <div class="suggestions">
        <span class="suggestion-label">Try a sample claim</span>
        <button class="suggestion-chip" onclick="fillClaim(this)">US inflation has been declining in 2025</button>
        <button class="suggestion-chip" onclick="fillClaim(this)">Apple launched a foldable iPhone in 2025</button>
        <button class="suggestion-chip" onclick="fillClaim(this)">OpenAI released a new flagship model in 2025</button>
        <button class="suggestion-chip" onclick="fillClaim(this)">The US and China signed a trade agreement in 2025</button>
      </div>
      <% } %>

      <!-- Status bar (visible while loading, or shows last fetch time) -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <!-- Results -->
      <% if (typeof sources !== 'undefined' && sources) { %>
      <div class="result-grid">
        <%- include('partials/sourceReport', { sources: sources }) %>
        <%- include('partials/answerPanel', { answer: answer, claim: claim }) %>
      </div>
      <% } %>

    </div>
  </main>

  <script>
    function fillClaim(btn) {
      document.getElementById('claimInput').value = btn.textContent.trim();
      document.getElementById('claimInput').focus();
    }

    // Show loading state on submit
    const form = document.getElementById('claimForm');
    const submitBtn = document.getElementById('submitBtn');

    form.addEventListener('submit', function () {
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner"></span> Retrieving…';
    });

    // Auto-grow textarea
    const ta = document.getElementById('claimInput');
    ta.addEventListener('input', function () {
      this.style.height = 'auto';
      this.style.height = this.scrollHeight + 'px';
    });
  </script>

</body>
</html>
